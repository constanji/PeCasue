# Dockerfile.multi
# v0.8.1-rc2

# Base for all builds
# buildx 使用独立 builder 容器拉基础镜像，多数情况下不会走你在本机 Docker Desktop 里配置的 Hub 镜像加速，
# 直连 registry-1.docker.io 时易出现 `auth.docker.io` TLS handshake timeout。
# 默认使用 DaoCloud 对 library 的镜像（国内通常更稳）；若你环境 DaoCloud 反而超时，请显式改回 Hub：
#   docker buildx build ... --build-arg NODE_IMAGE=node:20-bookworm-slim
ARG NODE_IMAGE=docker.m.daocloud.io/library/node:20-bookworm-slim
FROM ${NODE_IMAGE} AS base-min
WORKDIR /app
# 安装构建工具和 Python（用于编译 native 模块如 sharp）
# 安装 vips 以便 sharp 可以使用系统 libvips，避免下载二进制文件
# 安装 jemalloc（可选，用于内存优化）
# Debian 自带 glibc，无需额外安装，完美支持 onnxruntime-node
# buildx 容器内直连 deb.debian.org 常失败；统一换阿里云并加 apt 重试（exit 100 多为拉包超时/源未改全）
# 注意：Dockerfile 里勿用 "$$1" 传参给函数，BuildKit 会错误展开成字面量 "11"；改用循环 + "$$f"
RUN set -eux; \
  export DEBIAN_FRONTEND=noninteractive; \
  for f in /etc/apt/sources.list /etc/apt/sources.list.d/debian.sources; do \
    [ -f "$$f" ] || continue; \
    sed -i \
      -e 's|http://deb.debian.org|https://mirrors.aliyun.com|g' \
      -e 's|https://deb.debian.org|https://mirrors.aliyun.com|g' \
      -e 's|http://security.debian.org/debian-security|https://mirrors.aliyun.com/debian-security|g' \
      -e 's|https://security.debian.org/debian-security|https://mirrors.aliyun.com/debian-security|g' \
      -e 's|http://security.debian.org|https://mirrors.aliyun.com/debian-security|g' \
      -e 's|https://security.debian.org|https://mirrors.aliyun.com/debian-security|g' \
      "$$f"; \
  done; \
  if [ -d /etc/apt/sources.list.d ]; then \
    for f in /etc/apt/sources.list.d/*.list; do [ -f "$$f" ] || continue; \
      sed -i \
        -e 's|http://deb.debian.org|https://mirrors.aliyun.com|g' \
        -e 's|https://deb.debian.org|https://mirrors.aliyun.com|g' \
        -e 's|http://security.debian.org/debian-security|https://mirrors.aliyun.com/debian-security|g' \
        -e 's|https://security.debian.org/debian-security|https://mirrors.aliyun.com/debian-security|g' \
        -e 's|http://security.debian.org|https://mirrors.aliyun.com/debian-security|g' \
        -e 's|https://security.debian.org|https://mirrors.aliyun.com/debian-security|g' \
        "$$f"; \
    done; \
  fi; \
  apt-get -o Acquire::Retries=5 -o Acquire::http::Timeout=120 -o Acquire::https::Timeout=120 update; \
  apt-get -o Acquire::Retries=5 -o Acquire::http::Timeout=120 -o Acquire::https::Timeout=120 install -y --no-install-recommends \
    curl \
    python3 \
    python3-pip \
    build-essential \
    pkg-config \
    libvips \
    libvips-dev \
    ca-certificates \
    libjemalloc2 \
  && rm -rf /var/lib/apt/lists/*
# sharp 0.33+：可用 SHARP_FORCE_GLOBAL_LIBVIPS 跳过下载
ENV SHARP_FORCE_GLOBAL_LIBVIPS=1
# sharp@0.32（@xenova 嵌套）install/libvips.js 读取该 env；勿用 npm config set（npm 10 拒绝未登记键）。
ENV npm_config_sharp_libvips_binary_host=https://npmmirror.com/mirrors/sharp-libvips
# sharp 0.32（@xenova/transformers 嵌套依赖）：用 pkg-config 检测 vips-cpp，Debian 多架构 .pc 在 /usr/lib/<triplet>/pkgconfig
# 默认 PATH 不含该目录 → 检测失败 → 走 GitHub 下载 → 国内易 aborted；显式设置后走「检测到系统 libvips → node-gyp 编译」分支
ENV PKG_CONFIG_PATH=/usr/local/lib/pkgconfig:/usr/lib/pkgconfig:/usr/lib/x86_64-linux-gnu/pkgconfig:/usr/lib/aarch64-linux-gnu/pkgconfig:/usr/lib/arm-linux-gnueabihf/pkgconfig
# jemalloc 库路径随 CPU 架构变化，不可写死 x86_64（arm64 构建会找不到文件并报 ld.so 错误，进而干扰 sharp 等 native 安装）
# 容器启动时按 dpkg 架构设置 LD_PRELOAD（构建阶段不再设置错误的 ENV）
RUN printf '%s\n' \
    '#!/bin/sh' \
    'set -e' \
    'ARCH=$(dpkg --print-architecture)' \
    'case "$ARCH" in' \
    '  amd64) T=x86_64-linux-gnu ;;' \
    '  arm64) T=aarch64-linux-gnu ;;' \
    '  armhf) T=arm-linux-gnueabihf ;;' \
    '  *) T= ;;' \
    'esac' \
    'if [ -n "$T" ] && [ -f "/usr/lib/$T/libjemalloc.so.2" ]; then' \
    '  export LD_PRELOAD="/usr/lib/$T/libjemalloc.so.2"' \
    'fi' \
    'exec "$@"' \
    > /usr/local/bin/docker-entrypoint.sh && chmod +x /usr/local/bin/docker-entrypoint.sh
# 配置 npm 镜像源和重试设置（解决网络问题）
RUN npm config set registry https://registry.npmmirror.com && \
    npm config set fetch-retry-maxtimeout 600000 && \
    npm config set fetch-retries 5 && \
    npm config set fetch-retry-mintimeout 15000
# sharp@0.32（@xenova 嵌套）：install/libvips 若走网络，Node 流式拉取大文件易 aborted；
# 先用 curl 整块下载到 npm 缓存路径，安装时命中「Using cached …」逻辑（见 sharp install/libvips.js）。
# 使用 TARGETARCH build arg 避免 $$ 转义在 buildx 中的异常行为
ARG TARGETARCH=amd64
RUN set -eux; \
  ARCH="${TARGETARCH}"; \
  case "$ARCH" in \
    amd64) PLAT=linux-x64 ;; \
    arm64) PLAT=linux-arm64v8 ;; \
    *) echo "Dockerfile.multi: 请为 $ARCH 增补 sharp-libvips 平台名" >&2; exit 1 ;; \
  esac; \
  F="libvips-8.14.5-${PLAT}.tar.br"; \
  mkdir -p /root/.npm/_libvips; \
  curl -fSL --connect-timeout 30 --retry 30 --retry-delay 10 --retry-all-errors \
    --max-time 0 -o "/root/.npm/_libvips/${F}" \
    "https://cdn.npmmirror.com/binaries/sharp-libvips/v8.14.5/${F}"; \
  ls -lah "/root/.npm/_libvips/${F}"
# 配置 node-gyp 使用 Python3（通过环境变量）
ENV PYTHON=python3
COPY package*.json ./
COPY packages/data-provider/package*.json ./packages/data-provider/
COPY packages/api/package*.json ./packages/api/
COPY packages/data-schemas/package*.json ./packages/data-schemas/
COPY packages/client/package*.json ./packages/client/
COPY client/package*.json ./client/
COPY api/package*.json ./api/

# Build agents-because before installing dependencies
FROM base-min AS agents-build
WORKDIR /app
COPY agents-because/package.json ./agents-because/package.json
COPY agents-because/tsconfig*.json ./agents-because/
COPY agents-because/rollup.config.js ./agents-because/
COPY agents-because/husky-setup.js ./agents-because/
COPY agents-because/src ./agents-because/src
# Copy dist if it exists locally (will be used to skip build)
COPY agents-because/dist ./agents-because/dist
ENV DISABLE_SOURCEMAP=true
ENV NODE_OPTIONS="--max-old-space-size=8192"
# Build only if dist doesn't exist or is empty
RUN     if [ ! -d "agents-because/dist" ] || [ -z "$(ls -A agents-because/dist 2>/dev/null)" ]; then \
      echo "Building agents-because (dist not found)..."; \
      cd agents-because && npm install --no-audit --legacy-peer-deps && DISABLE_SOURCEMAP=true npm run build; \
    else \
      echo "Using existing dist directory, skipping build"; \
    fi

# Install all dependencies for every build
# 这个阶段只负责安装依赖，不进行构建
FROM base-min AS base-deps
WORKDIR /app
COPY --from=agents-build /app/agents-because/dist ./agents-because/dist
COPY --from=agents-build /app/agents-because/package.json ./agents-because/package.json
COPY --from=agents-build /app/agents-because/husky-setup.js ./agents-because/husky-setup.js
# 复制所有 package.json 文件（包括 client），确保 npm install 能识别所有工作区
COPY package*.json ./
COPY packages/data-provider/package*.json ./packages/data-provider/
COPY packages/api/package*.json ./packages/api/
COPY packages/data-schemas/package*.json ./packages/data-schemas/
COPY packages/client/package*.json ./packages/client/
COPY client/package*.json ./client/
COPY api/package*.json ./api/
ENV HUSKY=0
ENV CI=true
# root workspaces install 体量大，跨境/镜像偶发 ECONNRESET；加长超时并在 shell 层重试
RUN npm config set registry https://registry.npmmirror.com && \
    npm config set fetch-retries 15 && \
    npm config set fetch-retry-maxtimeout 600000 && \
    npm config set fetch-retry-mintimeout 20000 && \
    npm config set fetch-timeout 600000 || true
# 使用 npm install --legacy-peer-deps 替代 npm ci，解决 @langchain/core 版本冲突
# @because/api 需要 @langchain/core@^1.0.0，但其他包需要 0.3.x
# npm ci 不支持 --legacy-peer-deps，必须使用 npm install
# 安装所有工作区的依赖（包括 client 的所有依赖）
RUN set -eux; \
  attempt=1; \
  max=5; \
  while [ "$attempt" -le "$max" ]; do \
    if npm install --legacy-peer-deps --no-audit --no-fund; then \
      exit 0; \
    fi; \
    echo "npm install failed (attempt $attempt/$max), retry in 60s..."; \
    attempt=$((attempt + 1)); \
    sleep 60; \
  done; \
  exit 1

# Base stage with dependencies installed
FROM base-deps AS base
WORKDIR /app

# Build `data-provider` package
# 继承 base-deps 确保有完整的 node_modules
# 跨平台构建：宿主机 Mac arm64，目标 linux/amd64，需显式安装 linux rollup 原生模块
FROM base-deps AS data-provider-build
WORKDIR /app
COPY packages/data-provider ./packages/data-provider
ENV NODE_OPTIONS="--max-old-space-size=4096"
RUN npm install @rollup/rollup-linux-x64-gnu --no-save --legacy-peer-deps 2>/dev/null || true
WORKDIR /app/packages/data-provider
RUN npm run build

# Build `data-schemas` package
# 继承 base-deps 确保有完整的 node_modules
FROM base-deps AS data-schemas-build
WORKDIR /app
COPY packages/data-schemas ./packages/data-schemas
COPY --from=data-provider-build /app/packages/data-provider/dist /app/packages/data-provider/dist
ENV NODE_OPTIONS="--max-old-space-size=4096"
RUN npm install @rollup/rollup-linux-x64-gnu --no-save --legacy-peer-deps 2>/dev/null || true
WORKDIR /app/packages/data-schemas
RUN npm run build

# Build `api` package
# 继承 base-deps 确保有完整的 node_modules
FROM base-deps AS api-package-build
WORKDIR /app
COPY packages/api ./packages/api
COPY --from=data-provider-build /app/packages/data-provider/dist /app/packages/data-provider/dist
COPY --from=data-schemas-build /app/packages/data-schemas/dist /app/packages/data-schemas/dist
ENV NODE_OPTIONS="--max-old-space-size=8192"
RUN npm install @rollup/rollup-linux-x64-gnu --no-save --legacy-peer-deps 2>/dev/null || true
WORKDIR /app/packages/api
RUN npm run build

# Build `client` package
# 使用本地预构建的 packages/client/dist，绕过 Docker 内构建的依赖路径问题
# 构建前需要在本地执行: npm run build:client-package
FROM base-min AS client-package-build
WORKDIR /app
# 直接复制本地已构建的 packages/client/dist 目录
# 如果本地没有构建，会失败并提示需要先构建
COPY packages/client/dist ./packages/client/dist
# 验证 dist 目录存在
RUN test -d "/app/packages/client/dist" || (echo "ERROR: packages/client/dist not found. Please build client package locally first: npm run build:client-package" && exit 1)

# Client build
# 使用本地预构建的 client/dist，绕过 Docker 内构建的依赖路径问题
# 构建前需要在本地执行: npm run build:client-package && cd client && npm run build
FROM base-min AS client-build
WORKDIR /app
# 直接复制本地已构建的 client/dist 目录
# 如果本地没有构建，会失败并提示需要先构建
COPY client/dist ./client/dist
# 验证 dist 目录存在
RUN test -d "/app/client/dist" || (echo "ERROR: client/dist not found. Please build client locally first: npm run build:client-package && cd client && npm run build" && exit 1)

# API setup (including client dist)
FROM base-min AS api-build
# Add `uv` for extended MCP support (required for MCP functionality)
# 注意：Python、vips 和构建工具已在 base-min 阶段安装
# 安装策略：优先 GitHub Release 拉取静态 uv 二进制（避免 pip 下载 25MB wheel 在国内镜像易超时）；
# 失败则依次用 pip：清华 -> 阿里云 -> 官方 PyPI，并加长超时与重试。
ARG UV_VERSION=0.6.13
RUN set -eux; \
    ARCH="$(dpkg --print-architecture)"; \
    case "$ARCH" in \
      amd64) UV_ARCH=x86_64-unknown-linux-gnu ;; \
      arm64) UV_ARCH=aarch64-unknown-linux-gnu ;; \
      *) echo "unsupported arch: $ARCH" >&2; exit 1 ;; \
    esac; \
    if curl -fsSL --connect-timeout 30 --max-time 900 --retry 10 --retry-delay 5 \
      -o /tmp/uv.tgz "https://github.com/astral-sh/uv/releases/download/${UV_VERSION}/uv-${UV_ARCH}.tar.gz"; then \
      tar -xzf /tmp/uv.tgz --strip-components=1 -C /usr/local/bin; \
      rm -f /tmp/uv.tgz; \
      chmod +x /usr/local/bin/uv; \
    else \
      pip3 install --break-system-packages \
        --default-timeout=600 --retries=30 \
        -i https://pypi.tuna.tsinghua.edu.cn/simple \
        --trusted-host pypi.tuna.tsinghua.edu.cn \
        "uv==${UV_VERSION}" \
      || pip3 install --break-system-packages \
        --default-timeout=600 --retries=30 \
        -i https://mirrors.aliyun.com/pypi/simple/ \
        --trusted-host mirrors.aliyun.com \
        "uv==${UV_VERSION}" \
      || pip3 install --break-system-packages \
        --default-timeout=600 --retries=30 \
        "uv==${UV_VERSION}"; \
    fi; \
    uv --version; \
    echo "uv installed successfully"
WORKDIR /app
# Copy package files and agents-because dist before installing dependencies
COPY package*.json ./
COPY --from=agents-build /app/agents-because/dist ./agents-because/dist
COPY --from=agents-build /app/agents-because/package.json ./agents-because/package.json
# Copy husky-setup.js to avoid prepare script failure
COPY --from=agents-build /app/agents-because/husky-setup.js ./agents-because/husky-setup.js
# Set environment variables to skip husky setup
ENV HUSKY=0
ENV CI=true
# 配置 npm 镜像源（解决网络问题）
RUN npm config set registry https://registry.npmmirror.com && \
    npm config set fetch-retry-maxtimeout 600000 && \
    npm config set fetch-retries 5 && \
    npm config set fetch-retry-mintimeout 15000
# Install only production deps
# sharp@0.33+（根依赖）可走系统 libvips + SHARP_FORCE_GLOBAL_LIBVIPS；嵌套 sharp@0.32（@xenova）仍会拉 libvips 预编译包，
# base-min 已通过 ENV npm_config_sharp_libvips_binary_host 走 npmmirror，避免直连 GitHub。
# 使用 npm install --legacy-peer-deps 替代 npm ci，解决 @langchain/core 版本冲突
RUN npm install --omit=dev --legacy-peer-deps
# Certain build artifacts need mongodb runtime deps (may not be prod deps)
RUN npm install mongodb --omit=dev --legacy-peer-deps
# 跨平台构建：宿主机 Mac arm64 → 容器 linux/amd64
# npm install 可能从 package-lock.json 安装了 @sharp/darwin-arm64，需显式安装 linux-x64 原生模块
# sharp 0.33+ 使用 @sharp/linux-x64 可选包
RUN npm install @sharp/linux-x64 --no-save --legacy-peer-deps 2>/dev/null || \
    npm install @img/sharp-linux-x64 --no-save --legacy-peer-deps 2>/dev/null || true
RUN node -e "require('sharp'); console.log('✓ sharp linux binding OK', require('sharp').versions);"
# Fix case-sensitive imports: @Because/* -> @because/*
RUN ln -s /app/node_modules/@because /app/node_modules/@Because || true
# 验证关键依赖是否正确安装（特别是 @xenova/transformers）
# Debian 自带 glibc，无需设置 LD_LIBRARY_PATH，onnxruntime-node 可以直接工作
RUN node -e "try { const path = require.resolve('@xenova/transformers'); console.log('✓ @xenova/transformers found at:', path); require('@xenova/transformers'); console.log('✓ @xenova/transformers loaded successfully'); } catch(e) { console.error('✗ @xenova/transformers error:', e.message, e.stack); process.exit(1); }"
COPY api ./api
COPY config ./config
COPY specs ./specs
COPY BeCauseSkills ./BeCauseSkills
COPY Because-2.0 ./Because-2.0
COPY --from=data-provider-build /app/packages/data-provider/dist ./packages/data-provider/dist
COPY --from=data-schemas-build /app/packages/data-schemas/dist ./packages/data-schemas/dist
COPY --from=api-package-build /app/packages/api/dist ./packages/api/dist
COPY --from=client-build /app/client/dist ./client/dist
# 确保 specs、BeCauseSkills、Because-2.0 目录有正确的权限（可读）
RUN chmod -R 755 /app/specs && find /app/specs -type f -exec chmod 644 {} \; && \
    chmod -R 755 /app/BeCauseSkills && find /app/BeCauseSkills -type f -exec chmod 644 {} \; && \
    chmod -R 755 /app/Because-2.0 && find /app/Because-2.0 -type f -exec chmod 644 {} \;
# 保持 WORKDIR 在 /app，这样 process.cwd() = /app，相对路径 specs/... 会正确解析到 /app/specs/...
WORKDIR /app
EXPOSE 3080
ENV HOST=0.0.0.0
ENTRYPOINT ["/usr/local/bin/docker-entrypoint.sh"]
CMD ["node", "api/server/index.js"]