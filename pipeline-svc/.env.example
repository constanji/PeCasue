# pipeline-svc local dev env (copy to .env, never commit secrets)
# All values are optional; defaults make pipeline-svc usable without LLM.

# --- HTTP ---
PIPELINE_SVC_HOST=127.0.0.1
PIPELINE_SVC_PORT=8001

# --- Storage ---
# Where extracted/raw/output files live. Defaults to <pkg>/var/data.
# PIPELINE_DATA_DIR=/absolute/path/to/data

# --- Own-flow rules ---
# auto（默认）：优先 own_flow_processing/current.json（≥10 条）→ rules/处理表 → 代码硬编码兜底。
# embedded：完全使用代码内嵌规则，不解析上传的处理表 JSON / 处理表 xlsx（与 pingpong-master 硬编码对齐、避免向导内容写错导致漏匹配）。
# PIPELINE_OWN_FLOW_RULES_SOURCE=embedded

# --- Rule store password-book key (Fernet) ---
# 32 url-safe base64 bytes. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If unset, the password book is stored in plaintext (dev-only).
# PIPELINE_RULES_FERNET_KEY=

# --- LLM (AgentScope) ---
# Master switch. When 0/empty, all 4 agents (Password / UnknownChannel /
# Mapper / Copilot) silently fall back to deterministic heuristics.
PIPELINE_LLM_ENABLED=0

# Provider config (only read when PIPELINE_LLM_ENABLED=1).
# Mirrors pingpong-master semantics so a single .env can power both services.
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL_NAME=

# --- Copilot 多轮上下文（服务端窗口 + soft-trim，参考 agents-because context pruning）---
# PIPELINE_COPILOT_HISTORY_MAX_MESSAGES=24
# PIPELINE_COPILOT_HISTORY_USER_MAX_CHARS=12000
# PIPELINE_COPILOT_HISTORY_ASSISTANT_MAX_CHARS=16000
# PIPELINE_COPILOT_HISTORY_SOFT_HEAD_CHARS=3500
# PIPELINE_COPILOT_HISTORY_SOFT_TAIL_CHARS=3500
